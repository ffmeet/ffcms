{
    "name": "laravel/laravel",
    "type": "project",
    "description": "Laravel CMS with Filament v5",
    "require": {
        "php": "^8.2",
        "businesstilto/commentable": "^0.3.7",
        "filament/filament": "^5.3",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.10",
        "slimani/filament-media-manager": "^0.9.11"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.24",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "scripts": {
        "post-autoload-dump": [
            "@php artisan filament:upgrade"
        ]
    },
    "repositories": {
        "packagist": {
            "type": "composer",
            "url": "https://repo.packagist.org"
        }
    }
}
